{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "target": "ESNext",
    "lib": [
      "esnext",
      "dom"
    ],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "lib",
    "module": "ESNext",
    "skipLibCheck": true,
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "strictPropertyInitialization": false
  },
  "exclude": [
    "dist",
    "node_modules",
    "storybook-static",
    "src/**/*.stories.tsx",
    "src/storybook-utils"
  ],
  "include": [
    "src/**/*",
    "lib/index.d.ts" // declaration file path
  ]
}
